# POPMAP Environment Configuration
# Copy this file to .env and fill in your values
# On Linux/macOS: cp .env.example .env
# On Windows: copy .env.example .env

# Flask secret key for session management (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# POPMAP connection secret for verifying connection IDs (generate with: openssl rand -hex 32)
# IMPORTANT: Server and all clients must have the same value
POPMAP_CONNECTION_SECRET=your_connection_secret_here

# Email configuration for OTP authentication (optional but recommended)
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# Server URL (optional - auto-detected for localhost/codespaces/ngrok)
# SERVER_URL=http://localhost:5001
